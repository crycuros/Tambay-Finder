# === FREE No Credit Card Needed ===

# Option 1: Your own JSON file (upload to GitHub Pages or any hosting)
# Create a places.json file with your data
VITE_PLACES_JSON_URL=https://your-username.github.io/your-repo/places.json

# Option 2: Geoapify (free tier, no credit card)
# Sign up: https://www.geoapify.com/pricing
VITE_GEOAPIFY_KEY=

# === Requires Credit Card ($200/mo free) ===
# Google Maps Places API
# Sign up: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_API_KEY=

# Optional: Groq AI for smart recommendations
VITE_GROQ_API_KEY=